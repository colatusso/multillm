# Copy to .env and fill in:  cp .env.example .env
# .env is NOT committed (see .gitignore). `export ...` in the shell takes precedence.

# openrouter backend (Qwen, DeepSeek, GLM, etc.):
OPENROUTER_API_KEY=sk-or-...

# claude backend (`claude -p`) needs NO key: it uses the logged-in session (OAuth).
# Only set ANTHROPIC_API_KEY if you use `bare: true` in agents.yaml.
# ANTHROPIC_API_KEY=sk-ant-...
